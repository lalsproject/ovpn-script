<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Semua User — OpenVPN Panel</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon"
        href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🛡️</text></svg>">
</head>

<body>
    <div class="app-layout">
        <%- include('partials/sidebar') %>

            <div class="main-wrapper">
                <header class="top-bar">
                    <div style="font-weight: 700; font-size: 1.125rem;">Status Koneksi</div>
                    <div style="display: flex; gap: 0.75rem; align-items: center;">
                        <button class="theme-toggle" onclick="toggleTheme()" title="Ganti Tema">
                            <span id="themeIcon">🌙</span>
                        </button>
                        <button class="btn btn-outline btn-sm" onclick="location.reload()">🔄 Refresh</button>
                    </div>
                </header>

                <div class="container">
                    <!-- Status Cards -->
                    <div class="stats-grid">
                        <div class="stat-item" style="border-bottom: 3px solid var(--success);">
                            <div class="stat-label">Sedang Terhubung</div>
                            <div class="stat-value">
                                <%= activeUsers.length %>
                            </div>
                        </div>
                        <div class="stat-item" style="border-bottom: 3px solid var(--text-muted);">
                            <div class="stat-label">Total Terdaftar</div>
                            <div class="stat-value">
                                <%= registeredUsers.length %>
                            </div>
                        </div>
                    </div>

                    <!-- Active Users Detailed -->
                    <div style="margin-bottom: 2rem;">
                        <h4
                            style="font-size: 0.75rem; text-transform: uppercase; color: var(--text-muted); margin-bottom: 1rem; letter-spacing: 0.05em;">
                            Detail Koneksi Aktif</h4>
                        <div
                            style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 1rem;">
                            <% if (activeUsers.length===0) { %>
                                <div
                                    style="grid-column: 1/-1; padding: 3rem; background: var(--bg-card); border: 1px dashed var(--border-color); border-radius: 12px; text-align: center; color: var(--text-muted);">
                                    Tidak ada user yang terkoneksi ke daemon OpenVPN saat ini.
                                </div>
                                <% } else { %>
                                    <% activeUsers.forEach(function(u) { %>
                                        <div class="card" style="margin-bottom: 0;">
                                            <div class="card-body">
                                                <div
                                                    style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
                                                    <div>
                                                        <div style="font-weight: 700; font-size: 1.125rem;">
                                                            <%= u.name %>
                                                        </div>
                                                        <div
                                                            style="font-size: 0.75rem; font-family: 'JetBrains Mono', monospace; color: var(--ovpn-orange);">
                                                            <%= u.vpnIp || 'VPN IP Pending' %>
                                                        </div>
                                                    </div>
                                                    <span class="status-indicator status-online">Connected</span>
                                                </div>
                                                <div
                                                    style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; font-size: 0.8125rem;">
                                                    <div>
                                                        <div style="color: var(--text-muted);">Real IP</div>
                                                        <div style="font-weight: 500;">
                                                            <%= u.realIp %>
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <div style="color: var(--text-muted);">Uptime</div>
                                                        <div style="font-weight: 500;">
                                                            <%= u.connected %>
                                                        </div>
                                                    </div>
                                                    <div style="grid-column: 1/-1;">
                                                        <div style="color: var(--text-muted); margin-bottom: 0.25rem;">
                                                            Traffic (RX / TX)</div>
                                                        <div
                                                            style="font-weight: 600; font-family: 'JetBrains Mono', monospace;">
                                                            <%= u.traffic %>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <% }); %>
                                            <% } %>
                        </div>
                    </div>

                    <!-- Summary Raw Output -->
                    <div class="card">
                        <div class="card-header" style="cursor: pointer;"
                            onclick="document.getElementById('rawOut').style.display = document.getElementById('rawOut').style.display === 'none' ? 'block' : 'none'">
                            <h3 style="font-size: 0.8125rem;">📄 Log Status Server (Raw)</h3>
                            <span style="font-size: 0.75rem; color: var(--text-muted);">Klik untuk detail</span>
                        </div>
                        <div class="card-body" id="rawOut" style="display: none; background: var(--bg-primary);">
                            <pre
                                style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: var(--text-secondary); white-space: pre-wrap;"><%= rawOutput %></pre>
                        </div>
                    </div>
                </div>
            </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const theme = document.documentElement.getAttribute('data-theme');
            const icon = document.getElementById('themeIcon');
            if (icon) icon.textContent = theme === 'light' ? '🌙' : '☀️';
        });
    </script>
</body>

</html>