<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tambah User — OpenVPN Panel</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon"
        href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🛡️</text></svg>">
</head>

<body>
    <div class="app-layout">
        <%- include('partials/sidebar') %>

            <div class="main-wrapper">
                <header class="top-bar">
                    <div style="font-weight: 700; font-size: 1.125rem;">Tambah User Baru</div>
                    <div style="display: flex; gap: 0.75rem; align-items: center;">
                        <button class="theme-toggle" onclick="toggleTheme()" title="Ganti Tema">
                            <span id="themeIcon">🌙</span>
                        </button>
                        <a href="/" class="btn btn-outline btn-sm">🔙 Kembali</a>
                    </div>
                </header>

                <div class="container" style="max-width: 800px;">
                    <% if (result) { %>
                        <div class="card"
                            style="border-left: 4px solid <%= result.success ? 'var(--success)' : 'var(--danger)' %>; margin-bottom: 2rem;">
                            <div class="card-body">
                                <h4 style="margin-bottom: 0.5rem; display: flex; align-items: center; gap: 8px;">
                                    <%= result.success ? '✅ Berhasil' : '❌ Gagal' %>
                                </h4>
                                <p style="font-size: 0.875rem; color: var(--text-secondary);">
                                    <%= result.success ? 'User berhasil dibuat dan sertifikat telah diterbitkan.' :
                                        (result.error || 'Terjadi kesalahan saat memproses permintaan.' ) %>
                                </p>
                            </div>
                        </div>
                        <% } %>

                            <div class="card">
                                <div class="card-header">
                                    <h3 style="font-size: 1rem;">📝 Form Pendaftaran User</h3>
                                </div>
                                <div class="card-body">
                                    <form method="POST" action="/add-user" id="addUserForm">
                                        <div class="form-group">
                                            <label class="form-label" for="username">Nama Pengguna (Username)</label>
                                            <input type="text" id="username" name="username" class="form-input"
                                                placeholder="Misal: client-jakarta-01" required
                                                pattern="[a-zA-Z0-9_-]+">
                                            <div
                                                style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.5rem;">
                                                Hanya boleh berisi huruf, angka, underscore (_) dan dash (-).
                                            </div>
                                        </div>

                                        <div class="form-group">
                                            <label class="form-label" for="subnets">Subnet Lokal (Optional)</label>
                                            <input type="text" id="subnets" name="subnets" class="form-input"
                                                placeholder="192.168.1.0/24 10.10.10.0/24">
                                            <div
                                                style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.5rem;">
                                                Subnet yang bisa dijangkau dari sisi client. Pisahkan dengan spasi jika
                                                lebih dari satu.
                                            </div>
                                        </div>

                                        <div
                                            style="margin-top: 2rem; border-top: 1px solid var(--border-color); padding-top: 1.5rem; display: flex; justify-content: flex-end; gap: 1rem;">
                                            <button type="reset" class="btn btn-outline">Reset Form</button>
                                            <button type="submit" class="btn btn-primary" id="btnSubmit">
                                                <span id="btnText">➕ Buat User Sekarang</span>
                                                <div id="btnSpinner"
                                                    style="display:none; width: 16px; height: 16px; border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff; border-radius: 50%; animation: spin 0.8s linear infinite;">
                                                </div>
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>

                            <% if (result && result.output) { %>
                                <div class="card">
                                    <div class="card-header">
                                        <h3 style="font-size: 0.875rem;">📋 Terminal Output</h3>
                                    </div>
                                    <div class="card-body" style="background: var(--bg-primary); padding: 1rem;">
                                        <pre
                                            style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; white-space: pre-wrap; color: var(--text-secondary);"><%= result.output %></pre>
                                    </div>
                                </div>
                                <% } %>
                </div>
            </div>
    </div>

    <style>
        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }
    </style>

    <script>
        document.getElementById('addUserForm').addEventListener('submit', function () {
            document.getElementById('btnText').style.display = 'none';
            document.getElementById('btnSpinner').style.display = 'block';
            document.getElementById('btnSubmit').disabled = true;
            document.getElementById('btnSubmit').style.opacity = '0.8';
        });

        // Update theme icon on load
        document.addEventListener('DOMContentLoaded', () => {
            const theme = document.documentElement.getAttribute('data-theme');
            const icon = document.getElementById('themeIcon');
            if (icon) icon.textContent = theme === 'light' ? '🌙' : '☀️';
        });
    </script>
</body>

</html>