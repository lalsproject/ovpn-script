<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kelola Route — OpenVPN Panel</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon"
        href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🛡️</text></svg>">
</head>

<body>
    <div class="app-layout">
        <%- include('partials/sidebar') %>

            <div class="main-wrapper">
                <header class="top-bar">
                    <div style="font-weight: 700; font-size: 1.125rem;">Manajemen Routing (iroute)</div>
                    <div style="display: flex; gap: 0.75rem; align-items: center;">
                        <button class="theme-toggle" onclick="toggleTheme()" title="Ganti Tema">
                            <span id="themeIcon">🌙</span>
                        </button>
                        <a href="/" class="btn btn-outline btn-sm">🔙 Kembali</a>
                    </div>
                </header>

                <div class="container" style="max-width: 900px;">
                    <% if (result) { %>
                        <div class="card"
                            style="border-left: 4px solid <%= result.success ? 'var(--success)' : 'var(--danger)' %>; margin-bottom: 2rem;">
                            <div class="card-body">
                                <h4 style="margin-bottom: 0.5rem; display: flex; align-items: center; gap: 8px;">
                                    <%= result.success ? '✅ Berhasil' : '❌ Gagal' %>
                                </h4>
                                <p style="font-size: 0.875rem; color: var(--text-secondary);">
                                    <%= result.success ? 'Konfigurasi routing berhasil diperbarui di file CCD.' :
                                        (result.error || 'Gagal memperbarui route.' ) %>
                                </p>
                            </div>
                        </div>
                        <% } %>

                            <div class="card">
                                <div class="card-body" style="padding: 1.5rem;">
                                    <div
                                        style="display: flex; background: var(--bg-primary); padding: 4px; border-radius: 8px; margin-bottom: 2rem;">
                                        <button class="btn active-tab" id="tabAdd" onclick="switchRouteTab('add')"
                                            style="flex: 1; justify-content: center; background: none; border: none; font-size: 0.875rem; color: var(--text-muted);">➕
                                            Tambah Route</button>
                                        <button class="btn" id="tabRemove" onclick="switchRouteTab('remove')"
                                            style="flex: 1; justify-content: center; background: none; border: none; font-size: 0.875rem; color: var(--text-muted);">🗑️
                                            Hapus Route</button>
                                        <button class="btn" id="tabList" onclick="switchRouteTab('list')"
                                            style="flex: 1; justify-content: center; background: none; border: none; font-size: 0.875rem; color: var(--text-muted);">📋
                                            Daftar Route</button>
                                    </div>

                                    <!-- Form Tambah -->
                                    <div id="panelAdd" class="route-panel">
                                        <form method="POST" action="/routes/add">
                                            <div class="form-group">
                                                <label class="form-label">Pilih User</label>
                                                <select name="username" class="form-select" required>
                                                    <option value="">— Pilih user —</option>
                                                    <% users.forEach(function(u) { %>
                                                        <option value="<%= u %>" <%=selectedUser===u ? 'selected' : ''
                                                            %>><%= u %>
                                                        </option>
                                                        <% }); %>
                                                </select>
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">Network/Subnet</label>
                                                <input type="text" name="subnets" class="form-input"
                                                    placeholder="Misal: 192.168.10.0/24" required>
                                            </div>
                                            <div style="display: flex; justify-content: flex-end;">
                                                <button type="submit" class="btn btn-primary">➕ Tambahkan Route</button>
                                            </div>
                                        </form>
                                    </div>

                                    <!-- Form Hapus -->
                                    <div id="panelRemove" class="route-panel" style="display: none;">
                                        <form method="POST" action="/routes/remove">
                                            <div class="form-group">
                                                <label class="form-label">Pilih User</label>
                                                <select name="username" class="form-select" required>
                                                    <option value="">— Pilih user —</option>
                                                    <% users.forEach(function(u) { %>
                                                        <option value="<%= u %>" <%=selectedUser===u ? 'selected' : ''
                                                            %>><%= u %>
                                                        </option>
                                                        <% }); %>
                                                </select>
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">Subnet yang Akan Dihapus</label>
                                                <input type="text" name="subnets" class="form-input"
                                                    placeholder="Misal: 192.168.10.0/24" required>
                                            </div>
                                            <div style="display: flex; justify-content: flex-end;">
                                                <button type="submit" class="btn btn-primary"
                                                    style="background: var(--danger);">🗑️ Hapus Route Sekarang</button>
                                            </div>
                                        </form>
                                    </div>

                                    <!-- Panel List -->
                                    <div id="panelList" class="route-panel" style="display: none;">
                                        <form method="POST" action="/routes/list" id="formList">
                                            <div class="form-group">
                                                <label class="form-label">Pilih User untuk Dilihat Routenya</label>
                                                <select name="username" class="form-select" required
                                                    onchange="this.form.submit()">
                                                    <option value="">— Pilih user —</option>
                                                    <% users.forEach(function(u) { %>
                                                        <option value="<%= u %>" <%=selectedUser===u ? 'selected' : ''
                                                            %>><%= u %>
                                                        </option>
                                                        <% }); %>
                                                </select>
                                            </div>
                                        </form>

                                        <% if (routes) { %>
                                            <div style="margin-top: 1.5rem;">
                                                <h4
                                                    style="font-size: 0.8125rem; text-transform: uppercase; color: var(--text-muted); margin-bottom: 1rem;">
                                                    Route Aktif untuk <%= selectedUser %>
                                                </h4>
                                                <% if (routes.length> 0) { %>
                                                    <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                                                        <% routes.forEach(function(r) { %>
                                                            <div
                                                                style="display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1rem; background: var(--bg-primary); border: 1px solid var(--border-color); border-radius: 6px;">
                                                                <span
                                                                    style="font-family: 'JetBrains Mono', monospace; font-weight: 600; color: var(--ovpn-orange);">🔀
                                                                    <%= r.network %></span>
                                                                <span
                                                                    style="font-size: 0.75rem; color: var(--text-muted);">
                                                                    <%= r.mask %>
                                                                </span>
                                                            </div>
                                                            <% }); %>
                                                    </div>
                                                    <% } else { %>
                                                        <div
                                                            style="padding: 2rem; text-align: center; border: 1px dashed var(--border-color); border-radius: 8px; color: var(--text-muted);">
                                                            Tidak ada iroute yang terkonfigurasi untuk user ini.
                                                        </div>
                                                        <% } %>
                                            </div>
                                            <% } %>
                                    </div>
                                </div>
                            </div>

                            <% if (result && result.output) { %>
                                <div class="card" style="margin-top: 2rem;">
                                    <div class="card-body" style="background: var(--bg-primary); padding: 1rem;">
                                        <pre
                                            style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; white-space: pre-wrap; color: var(--text-secondary);"><%= result.output %></pre>
                                    </div>
                                </div>
                                <% } %>
                </div>
            </div>
    </div>

    <style>
        .active-tab {
            background: var(--bg-card) !important;
            color: var(--ovpn-orange) !important;
            box-shadow: var(--shadow-sm);
        }
    </style>

    <script>
        function switchRouteTab(tab) {
            // Hide all
            document.querySelectorAll('.route-panel').forEach(p => p.style.display = 'none');
            document.querySelectorAll('.btn').forEach(b => b.classList.remove('active-tab'));

            // Show selected
            document.getElementById('panel' + tab.charAt(0).toUpperCase() + tab.slice(1)).style.display = 'block';
            document.getElementById('tab' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add('active-tab');
        }

        // Auto-switch tab if routes data is present
        <% if (routes) { %>
            switchRouteTab('list');
        <% } %>

            // Update theme icon on load
            document.addEventListener('DOMContentLoaded', () => {
                const theme = document.documentElement.getAttribute('data-theme');
                const icon = document.getElementById('themeIcon');
                if (icon) icon.textContent = theme === 'light' ? '🌙' : '☀️';
            });
    </script>
</body>

</html>