<!-- Global Theme Script -->
<script>
    (function () {
        const theme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', theme);
    })();
</script>

<!-- Mobile Overlay -->
<div id="mobileOverlay" class="sidebar-overlay"
    style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:900;" onclick="toggleSidebar()">
</div>

<!-- Sidebar -->
<aside id="sidebar" class="sidebar">
    <div class="sidebar-header">
        <div class="sidebar-logo">O</div>
        <div class="sidebar-title">OpenVPN</div>
    </div>

    <nav class="sidebar-nav">
        <a href="/" class="nav-item <%= page === 'dashboard' ? 'active' : '' %>">
            <span class="nav-icon">📊</span> Dashboard
        </a>
        <a href="/show-users" class="nav-item <%= page === 'show-users' ? 'active' : '' %>">
            <span class="nav-icon">👥</span> Lihat User
        </a>
        <a href="/add-user" class="nav-item <%= page === 'add-user' ? 'active' : '' %>">
            <span class="nav-icon">➕</span> Tambah User
        </a>
        <a href="/del-user" class="nav-item <%= page === 'del-user' ? 'active' : '' %>">
            <span class="nav-icon">🗑️</span> Hapus User
        </a>
        <a href="/routes" class="nav-item <%= page === 'routes' ? 'active' : '' %>">
            <span class="nav-icon">🔀</span> Kelola Route
        </a>
    </nav>

    <div class="sidebar-footer">
        <div
            style="font-size: 0.8125rem; color: var(--text-on-sidebar); margin-bottom: 0.75rem; display: flex; align-items: center; gap: 8px;">
            <div
                style="width: 24px; height: 24px; background: var(--ovpn-orange); border-radius: 4px; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 10px;">
                <%= user ? user.charAt(0).toUpperCase() : 'A' %>
            </div>
            <%= user %>
        </div>
        <a href="/logout" class="btn btn-outline"
            style="width: 100%; border-color: rgba(255,255,255,0.1); color: var(--text-on-sidebar); font-size: 0.8125rem;">
            🚪 Keluar
        </a>
    </div>
</aside>

<!-- Top Bar for Theme and Mobile Toggle -->
<header class="top-bar-mobile" style="display: none;">
    <button class="mobile-nav-toggle" onclick="toggleSidebar()">☰</button>
    <div style="font-weight: 700;">OpenVPN</div>
    <div style="width: 40px;"></div> <!-- Spacer -->
</header>

<script>
    function toggleSidebar() {
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('mobileOverlay');
        sidebar.classList.toggle('open');
        overlay.style.display = sidebar.classList.contains('open') ? 'block' : 'none';
    }

    function toggleTheme() {
        const currentTheme = document.documentElement.getAttribute('data-theme');
        const newTheme = currentTheme === 'light' ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', newTheme);
        localStorage.setItem('theme', newTheme);

        // Update toggle icon if it exists
        const icon = document.getElementById('themeIcon');
        if (icon) icon.textContent = newTheme === 'light' ? '🌙' : '☀️';
    }
</script>

<style>
    @media (max-width: 1024px) {
        .top-bar-mobile {
            display: flex !important;
            height: 60px;
            background: var(--bg-secondary);
            border-bottom: 1px solid var(--border-color);
            align-items: center;
            justify-content: space-between;
            padding: 0 1rem;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .main-wrapper {
            margin-left: 0 !important;
        }
    }
</style>