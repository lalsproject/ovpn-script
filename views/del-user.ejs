<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hapus User — OpenVPN Panel</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon"
        href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🛡️</text></svg>">
</head>

<body>
    <div class="app-layout">
        <%- include('partials/sidebar') %>

            <div class="main-wrapper">
                <header class="top-bar">
                    <div style="font-weight: 700; font-size: 1.125rem;">Hapus User</div>
                    <div style="display: flex; gap: 0.75rem; align-items: center;">
                        <button class="theme-toggle" onclick="toggleTheme()" title="Ganti Tema">
                            <span id="themeIcon">🌙</span>
                        </button>
                        <a href="/" class="btn btn-outline btn-sm">🔙 Kembali</a>
                    </div>
                </header>

                <div class="container" style="max-width: 800px;">
                    <% if (result) { %>
                        <div class="card"
                            style="border-left: 4px solid <%= result.success ? 'var(--success)' : 'var(--danger)' %>; margin-bottom: 2rem;">
                            <div class="card-body">
                                <h4 style="margin-bottom: 0.5rem; display: flex; align-items: center; gap: 8px;">
                                    <%= result.success ? '✅ Berhasil' : '❌ Gagal' %>
                                </h4>
                                <p style="font-size: 0.875rem; color: var(--text-secondary);">
                                    <%= result.success ? 'User dan seluruh konfigurasinya telah dihapus dari server.' :
                                        (result.error || 'Gagal menghapus user.' ) %>
                                </p>
                            </div>
                        </div>
                        <% } %>

                            <div class="card">
                                <div class="card-header">
                                    <h3 style="font-size: 1rem; color: var(--danger);">⚠️ Tindakan Berbahaya</h3>
                                </div>
                                <div class="card-body">
                                    <form method="POST" action="/del-user" id="delUserForm"
                                        onsubmit="return confirmDelete()">
                                        <div class="form-group">
                                            <label class="form-label">Pilih User yang Akan Dihapus</label>
                                            <% if (users && users.length> 0) { %>
                                                <select id="username" name="username" class="form-select" required
                                                    onchange="handleUserSelect()">
                                                    <option value="">— Silakan pilih user —</option>
                                                    <% users.forEach(function(u) { %>
                                                        <option value="<%= u %>">
                                                            <%= u %>
                                                        </option>
                                                        <% }); %>
                                                </select>
                                                <% } else { %>
                                                    <div
                                                        style="padding: 1.5rem; background: var(--bg-primary); border-radius: 8px; text-align: center; color: var(--text-muted);">
                                                        Tidak ada user terdaftar di direktori CCD.
                                                    </div>
                                                    <% } %>
                                        </div>

                                        <div id="dangerZone"
                                            style="display: none; margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border-color);">
                                            <div
                                                style="background: var(--danger-bg); color: var(--danger); padding: 1rem; border-radius: 8px; font-size: 0.875rem; margin-bottom: 1.5rem;">
                                                <strong>Peringatan!</strong> Menghapus user akan merevoke sertifikat
                                                TLS/SSL mereka. Client tersebut tidak akan bisa terhubung lagi ke VPN.
                                            </div>

                                            <div class="form-group">
                                                <label class="form-label">Konfirmasi Nama User</label>
                                                <input type="text" id="confirmName" class="form-input"
                                                    placeholder="Tulis nama user untuk mengonfirmasi"
                                                    autocomplete="off">
                                                <div
                                                    style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.5rem;">
                                                    Ketik ulang <span id="targetName"
                                                        style="font-weight: 700; color: var(--text-primary);"></span>
                                                    untuk mengaktifkan tombol hapus.
                                                </div>
                                            </div>

                                            <div style="display: flex; justify-content: flex-end; gap: 1rem;">
                                                <button type="submit" id="btnDelete" class="btn btn-primary"
                                                    style="background: var(--danger); opacity: 0.5;" disabled>
                                                    🗑️ Konfirmasi & Hapus Permanen
                                                </button>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>

                            <% if (result && result.output) { %>
                                <div class="card" style="margin-top: 2rem;">
                                    <div class="card-header">
                                        <h3 style="font-size: 0.875rem;">📋 Terminal Output</h3>
                                    </div>
                                    <div class="card-body" style="background: var(--bg-primary); padding: 1rem;">
                                        <pre
                                            style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; white-space: pre-wrap; color: var(--text-secondary);"><%= result.output %></pre>
                                    </div>
                                </div>
                                <% } %>
                </div>
            </div>
    </div>

    <script>
        function handleUserSelect() {
            const select = document.getElementById('username');
            const zone = document.getElementById('dangerZone');
            const target = document.getElementById('targetName');
            const confirmInput = document.getElementById('confirmName');
            const btn = document.getElementById('btnDelete');

            if (select.value) {
                zone.style.display = 'block';
                target.textContent = select.value;
                confirmInput.value = '';
                btn.disabled = true;
                btn.style.opacity = '0.5';
            } else {
                zone.style.display = 'none';
            }
        }

        document.getElementById('confirmName').addEventListener('input', function () {
            const select = document.getElementById('username');
            const btn = document.getElementById('btnDelete');
            if (this.value === select.value) {
                btn.disabled = false;
                btn.style.opacity = '1';
            } else {
                btn.disabled = true;
                btn.style.opacity = '0.5';
            }
        });

        function confirmDelete() {
            const select = document.getElementById('username');
            return confirm(`Apakah Anda benar-benar yakin ingin menghapus user "${select.value}" secara permanen?`);
        }

        // Update theme icon on load
        document.addEventListener('DOMContentLoaded', () => {
            const theme = document.documentElement.getAttribute('data-theme');
            const icon = document.getElementById('themeIcon');
            if (icon) icon.textContent = theme === 'light' ? '🌙' : '☀️';
        });
    </script>
</body>

</html>